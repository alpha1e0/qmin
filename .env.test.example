# Qmin 单元测试配置示例
# 复制此文件为 .env.test 并填入实际的测试配置

# ================================
# LLM API 配置
# ================================

# OpenAI 兼容 API 配置
OPENAI_API_KEY=your-test-api-key-here
OPENAI_API_BASE=https://api.example.com/v1
OPENAI_API_MODEL=gpt-4

# API 代理配置（可选）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ================================
# 图像生成 API 配置
# ================================

# Flux API 配置
FLUX_API_KEY=your-flux-api-key
FLUX_API_BASE=https://flux-api.example.com
FLUX_API_MODEL=flux-pro

# Gemini API 配置
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE=https://generativelanguage.googleapis.com
GEMINI_API_MODEL=gemini-2.0-flash-exp-image-generation

# 通义万相 API 配置
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE=https://dashscope.aliyuncs.com
QWEN_API_MODEL=wanx-v1

# ================================
# 测试环境配置
# ================================

# 测试超时时间（毫秒）
TEST_TIMEOUT=30000

# 是否启用详细日志
TEST_VERBOSE_LOGGING=false

# 测试临时目录
TEST_TEMP_DIR=/tmp/qmin-test
