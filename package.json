{
  "name": "qmin",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "postinstall": "electron-builder install-app-deps && electron-rebuild",
    "postuninstall": "electron-builder install-app-deps",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:smoke": "playwright test e2e/smoke"
  },
  "main": "dist-electron/main/index.js",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vue/shared": "^3.5.29",
    "aes-js": "^4.0.0-beta.3",
    "axios": "^1.13.6",
    "better-sqlite3": "^11.7.0",
    "core-js": "^3.8.3",
    "element-plus": "^2.9.4",
    "https-proxy-agent": "^7.0.6",
    "openai": "^6.25.0",
    "sharp": "^0.33.5",
    "uuid": "^11.0.3",
    "vditor": "^3.10.7",
    "vue": "^3.2.13"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^3.1.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^12.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^1.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
